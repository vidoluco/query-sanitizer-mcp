# ─── Local model endpoint ───────────────────────────────────────────────────

# Ollama (default)
SANITIZER_MODEL_URL=http://localhost:11434/v1/chat/completions
SANITIZER_MODEL_NAME=llama3.2

# LM Studio
# SANITIZER_MODEL_URL=http://localhost:1234/v1/chat/completions
# SANITIZER_MODEL_NAME=lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF

# ─── Retry / reliability ─────────────────────────────────────────────────────

# Number of retries on local model failure (2s, 4s backoff). Default: 2
# Set to 0 for fastest fail (useful in tests or when using regex-only fallback)
# SANITIZER_MODEL_RETRIES=2

# ─── Ledger ───────────────────────────────────────────────────────────────────

# Where to write the redaction ledger (default: .sanitizer-ledger/ in cwd)
# SANITIZER_LEDGER_DIR=/path/to/your/.sanitizer-ledger

# Privacy mode: set to false to stop storing original values in the ledger.
# When false, restore_response only works within the same server session.
# Useful for GDPR Article 5(1)(f) compliance — no PII at rest.
# Default: true (originals stored for cross-session restore)
# SANITIZER_LEDGER_STORE_ORIGINALS=true
