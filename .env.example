# ─── LLM Backend ─────────────────────────────────────────────────────────────

# "ollama" (default, M4 MacBook) or "hf" (HuggingFace transformers, Colab)
# SANITIZER_BACKEND=ollama

# ─── Ollama — M4 MacBook (default) ───────────────────────────────────────────
# Ollama 0.19+ uses MLX backend automatically on Apple Silicon for ~50% speedup.
# Recommended model for DLP tasks: qwen2.5:3b (fast, accurate at instruction following)
#   ollama pull qwen2.5:3b && ollama serve
# Alternatives: phi4-mini (3.8B, strong reasoning), llama3.2 (original default)

SANITIZER_MODEL_URL=http://localhost:11434/v1/chat/completions
SANITIZER_MODEL_NAME=qwen2.5:3b

# ─── HuggingFace transformers — Google Colab ─────────────────────────────────
# Requires: pip install "query-sanitizer-mcp[colab]"
# Model auto-downloads from HuggingFace Hub on first run (~6GB for Qwen2.5-3B)
# Runs on T4 GPU (free Colab tier) at ~35 tok/s

# SANITIZER_BACKEND=hf
# SANITIZER_HF_MODEL=Qwen/Qwen2.5-3B-Instruct

# ─── GLiNER NER layer (Phase 1b) ─────────────────────────────────────────────
# Requires: pip install "query-sanitizer-mcp[nlp]"
# 205M parameter model, runs on CPU/MPS (M4) or CUDA (Colab T4). ~500MB download.
# Catches people, orgs, locations that regex alone misses.

# SANITIZER_GLINER_MODEL=urchade/gliner_medium-v2.1
# SANITIZER_GLINER_THRESHOLD=0.4

# ─── Retry / reliability ─────────────────────────────────────────────────────
# Retries on model failure with 2s, 4s exponential backoff. Set 0 to fail fast.
# SANITIZER_MODEL_RETRIES=2

# ─── Ledger ───────────────────────────────────────────────────────────────────
# SANITIZER_LEDGER_DIR=/path/to/.sanitizer-ledger

# Privacy mode: set false to stop storing originals at rest (GDPR Article 5(1)(f)).
# Restore works only within the same server session via in-memory cache.
# SANITIZER_LEDGER_STORE_ORIGINALS=true
